	"transcription": [
		{
			"timestamps": {
				"from": "00:00:00,000",
				"to": "00:00:15,060"
			},
			"offsets": {
				"from": 0,
				"to": 15060
			},
			"text": "清晨的阳光透过窗帘缝隙,在地毯上划出一道细长的光斑,卧室里弥漫着一股浓烈的刺鼻的石南花气味,混杂着汗水和女星体液发酵后的甜心,白夜雨醒了。"
		},
		{
			"timestamps": {
				"from": "00:00:15,620",
				"to": "00:00:20,020"
			},
			"offsets": {
				"from": 15620,
				"to": 20020
			},
			"text": "两位美人,起得真早,乖,让老公再醒醒。"
		},
		{
			"timestamps": {
				"from": "00:00:20,200",
				"to": "00:00:29,540"
			},
			"offsets": {
				"from": 20200,
				"to": 29540
			},
			"text": "凌乱不堪的大床上,波波和小薇一左一右的依偎在白夜雨身旁,那件红编女服装早就被撕成了几块破布。"
		},
		{
			"timestamps": {
				"from": "00:00:30,000",
				"to": "00:00:43,120"
			},
			"offsets": {
				"from": 30000,
				"to": 43120
			},
			"text": "可怜兮兮地挂在波波的腰间,她白皙的肌肤上布满了青紫色的吻痕和粗暴的纸印,尤其是大腿内侧,干涸的精液和饮水结成了一层薄薄的白霜。"
		},
		{
			"timestamps": {
				"from": "00:00:43,460",
				"to": "00:00:52,260"
			},
			"offsets": {
				"from": 43460,
				"to": 52260
			},
			"text": "稍微一动,红肿不堪的阴唇就传来一阵火辣辣的刺痛,提醒着她昨晚经历了怎样狂暴的摧残。"
		},
		{
			"timestamps": {
				"from": "00:00:52,960",
				"to": "00:00:57,440"
			},
			"offsets": {
				"from": 52960,
				"to": 57440
			},
			"text": "波波皱了皱眉,从极度的疲惫中缓缓睁开眼睛。"
		},
		{
			"timestamps": {
				"from": "00:00:58,660",
				"to": "00:01:08,360"
			},
			"offsets": {
				"from": 58660,
				"to": 68360
			},
			"text": "她感觉自己的骨头都快散架了,子宫深处甚至还残留着被那根粗壮肉棒反复撞击,灌满浓精的保障感。"
		},
		{
			"timestamps": {
				"from": "00:01:09,220",
				"to": "00:01:18,360"
			},
			"offsets": {
				"from": 69220,
				"to": 78360
			},
			"text": "她转过头,看着白夜雨熟睡的侧脸,又看了看另一边同样浑身赤裸,睡得毫无防备的小微。"
		},
		{
			"timestamps": {
				"from": "00:01:19,500",
				"to": "00:01:25,800"
			},
			"offsets": {
				"from": 79500,
				"to": 85800
			},
			"text": "昨晚那些荒唇,引你毫无底线的画面像电影一样在脑海里回放。"
		},
		{
			"timestamps": {
				"from": "00:01:26,840",
				"to": "00:01:30,820"
			},
			"offsets": {
				"from": 86840,
				"to": 90820
			},
			"text": "她不仅没有感到羞耻,反而像上瘾般凑过去。"
		},
		{
			"timestamps": {
				"from": "00:01:31,360",
				"to": "00:01:40,260"
			},
			"offsets": {
				"from": 91360,
				"to": 100260
			},
			"text": "将脸颊贴在白夜雨结实的胸膛上,像只燕族的母狗一样蹭了蹭,手指贪恋地抚摸着她腹肌的轮廓。"
		},
		{
			"timestamps": {
				"from": "00:01:41,360",
				"to": "00:01:45,420"
			},
			"offsets": {
				"from": 101360,
				"to": 105420
			},
			"text": "小微也被动静吵醒,她慵懒地伸了个懒腰。"
		},
		{
			"timestamps": {
				"from": "00:01:46,340",
				"to": "00:01:52,460"
			},
			"offsets": {
				"from": 106340,
				"to": 112460
			},
			"text": "地罩杯的白肉在晨光中晃了晃,上面还留着波波昨晚吸水出的红印。"
		},
		{
			"timestamps": {
				"from": "00:01:53,080",
				"to": "00:01:58,340"
			},
			"offsets": {
				"from": 113080,
				"to": 118340
			},
			"text": "她揉了揉酸痛的腰,声音沙哑得厉害,带着浓浓的鼻音。"
		},
		{
			"timestamps": {
				"from": "00:01:59,360",
				"to": "00:02:02,920"
			},
			"offsets": {
				"from": 119360,
				"to": 122920
			},
			"text": "感觉下面都被老公操烂了,肯定要被看出来。"
		},
		{
			"timestamps": {
				"from": "00:02:03,520",
				"to": "00:02:09,660"
			},
			"offsets": {
				"from": 123520,
				"to": 129660
			},
			"text": "波波轻笑了一声,眼底透着一股彻底堕落后的魅意,她翻了个身。"
		},
		{
			"timestamps": {
				"from": "00:02:10,580",
				"to": "00:02:16,920"
			},
			"offsets": {
				"from": 130580,
				"to": 136920
			},
			"text": "将一条长腿搭在白夜雨身上,任由泥泞干涸的血口敞露在空气中。"
		},
		{
			"timestamps": {
				"from": "00:02:17,320",
				"to": "00:02:21,240"
			},
			"offsets": {
				"from": 137320,
				"to": 141240
			},
			"text": "看出来就看出来呗,反正今天下午还有个闭门会。"
		},
		{
			"timestamps": {
				"from": "00:02:21,760",
				"to": "00:02:26,460"
			},
			"offsets": {
				"from": 141760,
				"to": 146460
			},
			"text": "你忘了昨晚答应老公的事了,我们还得想办法把沈总骗出来呢。"
		},
		{
			"timestamps": {
				"from": "00:02:26,880",
				"to": "00:02:33,780"
			},
			"offsets": {
				"from": 146880,
				"to": 153780
			},
			"text": "床头柜上的手机突然震动起来,是公司企划部群里发来的早安打卡提醒。"
		},
		{
			"timestamps": {
				"from": "00:02:34,220",
				"to": "00:02:44,340"
			},
			"offsets": {
				"from": 154220,
				"to": 164340
			},
			"text": "包包瞥了一眼屏幕,曾经让她神经紧绷的工作群,现在在她眼里,不过是替白夜雨挑选下一个恋物的后宫名册罢了。"
		}
	]
}
