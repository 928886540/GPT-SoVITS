	"transcription": [
		{
			"timestamps": {
				"from": "00:00:00,000",
				"to": "00:00:08,120"
			},
			"offsets": {
				"from": 0,
				"to": 8120
			},
			"text": "电梯钉了一声,停在指定楼层,金属门缓缓向两侧划开,走廊的感应灯随之亮起。"
		},
		{
			"timestamps": {
				"from": "00:00:09,300",
				"to": "00:00:11,960"
			},
			"offsets": {
				"from": 9300,
				"to": 11960
			},
			"text": "波波几乎是迫不及待的第一个迈出电梯。"
		},
		{
			"timestamps": {
				"from": "00:00:13,360",
				"to": "00:00:19,120"
			},
			"offsets": {
				"from": 13360,
				"to": 19120
			},
			"text": "他走得有些急,但双腿却因为大腿根部的粘腻感而显得僵硬。"
		},
		{
			"timestamps": {
				"from": "00:00:19,640",
				"to": "00:00:27,240"
			},
			"offsets": {
				"from": 19640,
				"to": 27240
			},
			"text": "每一次迈步,阴唇间残留的精液就不可避免地摩擦着湿透的内裤,带来一阵又痒又胀的战力。"
		},
		{
			"timestamps": {
				"from": "00:00:27,640",
				"to": "00:00:36,060"
			},
			"offsets": {
				"from": 27640,
				"to": 36060
			},
			"text": "他咬着夏春,双手紧紧捧着那杯已经不再温热的奶茶,目光直视前方白夜宇家的防盗门。"
		},
		{
			"timestamps": {
				"from": "00:00:36,520",
				"to": "00:00:42,160"
			},
			"offsets": {
				"from": 36520,
				"to": 42160
			},
			"text": "白夜宇走上前,掏出钥匙拧开门锁,门刚推开一条缝。"
		},
		{
			"timestamps": {
				"from": "00:00:43,360",
				"to": "00:00:45,520"
			},
			"offsets": {
				"from": 43360,
				"to": 45520
			},
			"text": "波波后便侧身挤了进去。"
		},
		{
			"timestamps": {
				"from": "00:00:45,900",
				"to": "00:00:46,880"
			},
			"offsets": {
				"from": 45900,
				"to": 46880
			},
			"text": "洗手间在哪儿?"
		},
		{
			"timestamps": {
				"from": "00:00:47,880",
				"to": "00:00:54,040"
			},
			"offsets": {
				"from": 47880,
				"to": 54040
			},
			"text": "他连客厅的灯都没等打开,声音压得很低,带着一丝压抑不住的急促。"
		},
		{
			"timestamps": {
				"from": "00:00:54,460",
				"to": "00:00:55,320"
			},
			"offsets": {
				"from": 54460,
				"to": 55320
			},
			"text": "左手边第二间。"
		},
		{
			"timestamps": {
				"from": "00:00:55,540",
				"to": "00:01:01,440"
			},
			"offsets": {
				"from": 55540,
				"to": 61440
			},
			"text": "白夜宇顺手按下玄关的开关,暖黄色的灯光瞬间照亮了客厅。"
		},
		{
			"timestamps": {
				"from": "00:01:02,020",
				"to": "00:01:06,880"
			},
			"offsets": {
				"from": 62020,
				"to": 66880
			},
			"text": "波波连拖鞋都没顾上换,直接踩着高跟鞋快步走向洗手间。"
		},
		{
			"timestamps": {
				"from": "00:01:08,180",
				"to": "00:01:14,320"
			},
			"offsets": {
				"from": 68180,
				"to": 74320
			},
			"text": "砰的一声,梦门被紧紧关上,紧接着传来了繁琐的喀哒声。"
		},
		{
			"timestamps": {
				"from": "00:01:15,140",
				"to": "00:01:23,240"
			},
			"offsets": {
				"from": 75140,
				"to": 83240
			},
			"text": "小薇慢悠悠地跟在后面进门,她踢掉脚上的单鞋,换上白夜宇递过来的客用拖鞋。"
		},
		{
			"timestamps": {
				"from": "00:01:24,120",
				"to": "00:01:32,340"
			},
			"offsets": {
				"from": 84120,
				"to": 92340
			},
			"text": "把两杯奶茶放在玄关柜上,她的目光在空荡荡的客厅扫了一圈,最后落在紧闭的洗手间门上。"
		},
		{
			"timestamps": {
				"from": "00:01:32,660",
				"to": "00:01:34,160"
			},
			"offsets": {
				"from": 92660,
				"to": 94160
			},
			"text": "看来是真的别坏了。"
		},
		{
			"timestamps": {
				"from": "00:01:34,940",
				"to": "00:01:42,300"
			},
			"offsets": {
				"from": 94940,
				"to": 102300
			},
			"text": "小薇轻笑了一声,转头看向白夜宇,眼神里带着毫不掩饰的探究。"
		},
		{
			"timestamps": {
				"from": "00:01:42,760",
				"to": "00:01:49,640"
			},
			"offsets": {
				"from": 102760,
				"to": 109640
			},
			"text": "晚唐平时可是个有洁癖的人,能让他忍着一路走到这儿,到底给他灌了多少啊?"
		},
		{
			"timestamps": {
				"from": "00:01:49,720",
				"to": "00:01:53,320"
			},
			"offsets": {
				"from": 109720,
				"to": 113320
			},
			"text": "洗手间里,水龙头被猛地拧开。"
		},
		{
			"timestamps": {
				"from": "00:01:54,380",
				"to": "00:02:00,200"
			},
			"offsets": {
				"from": 114380,
				"to": 120200
			},
			"text": "哗啦啦的水声瞬间响起,试图掩盖里面脱衣服的吸塑声。"
		},
		{
			"timestamps": {
				"from": "00:02:00,660",
				"to": "00:02:07,620"
			},
			"offsets": {
				"from": 120660,
				"to": 127620
			},
			"text": "波波靠在洗手台前,看着镜子里自己潮红的脸和凌乱的头发,呼吸急促。"
		},
		{
			"timestamps": {
				"from": "00:02:08,360",
				"to": "00:02:17,840"
			},
			"offsets": {
				"from": 128360,
				"to": 137840
			},
			"text": "她颤抖着手,解开西装裤的扣子,吞向那条已经完全被饮水和精液浸透,甚至能拉出粘稠白色的内裤。"
		},
		{
			"timestamps": {
				"from": "00:02:18,840",
				"to": "00:02:22,740"
			},
			"offsets": {
				"from": 138840,
				"to": 142740
			},
			"text": "大腿内侧的湿滑痕迹在灯光下无处遁形"
		}
	]
}
